@import url("https://fonts.googleapis.com/css2?family=BenchNine:wght@700&display=swap");
header .nav-top {
  display: flex;
  width: 65vw;
  margin: 2rem;
  background-color: rgba(0, 0, 0, 0.7);
  align-items: center;
}
header .nav-top a {
  text-decoration: none;
  color: #715226;
}
header .nav-top .icon {
  display: flex;
}
header .nav-top .icon img {
  width: 15%;
  opacity: 0.5;
}
header .nav-top .icon .name {
  margin-left: 1rem;
  margin-top: 0.5rem;
  color: white;
}
header .nav-top ul {
  display: flex;
  margin-left: auto;
}
header .nav-top ul li {
  display: flex;
  list-style-type: none;
  margin: 0 1rem;
}
header .nav-top ul li a:hover {
  border-bottom: #89181e 3px solid;
  cursor: pointer;
}
header .burger-menu {
  display: none;
}

.nav-bottom {
  background-color: rgba(0, 0, 0, 0.7);
  width: 65vw;
  height: 5%;
  position: fixed;
  bottom: 0;
  left: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  font-size: 1.5rem;
  margin: 2rem 15%;
}
.nav-bottom i {
  color: #89181e;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  scroll-behavior: smooth;
}

body {
  background-image: url(../../images/28175716.jpg);
  background-size: cover;
  background-repeat: no-repeat;
  background-position: top;
}

.container-home {
  height: 100vh;
  display: flex;
  justify-content: center;
}

.container-about {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.container-projects {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.container-contact {
  min-height: 100vh;
  display: flex;
  justify-content: center;
}

main {
  color: white;
  position: absolute;
  top: 40%;
  left: 17.5%;
}
main h1 {
  font-size: 80px;
  color: silver;
}
main p {
  width: 60%;
  height: 60%;
  margin-bottom: 2rem;
}
main a {
  padding: 0.5rem;
  background-color: #89181e;
  color: white;
  text-decoration: none;
}

.container-about .about {
  color: white;
  text-align: center;
  margin: 0 auto;
  width: 50%;
  margin-bottom: 10rem;
}
.container-about .about h1 {
  font-family: "BenchNine", sans-serif;
  color: #89181e;
  font-size: 3rem;
}
.container-about .about h3 {
  color: #3d0a10;
  font-family: "BenchNine", sans-serif;
  font-size: 1.8rem;
}
.container-about .about p {
  color: #000000;
}

.sub-container-projects {
  margin-top: 2rem;
  display: grid;
  grid-template-columns: 17.5vw repeat(12, 1fr) 17.5vw;
  grid-template-rows: repeat(10, 10%);
  gap: 0.5rem;
}

.project .pic {
  height: 60%;
}
.project .pic img {
  width: 100%;
}

.project-1 {
  grid-area: 1/2/4/8;
}

.project-2 {
  grid-area: 1/8/3/10;
}

.project-3 {
  grid-area: 1/10/3/14;
}

.project-4 {
  grid-area: 4/2/6/8;
}

.project-5 {
  grid-area: 3/10/5/14;
}

.project-6 {
  grid-area: 5/8/7/14;
}

.text {
  text-align: center;
  margin-top: 15%;
}

form {
  display: flex;
  flex-direction: column;
}

.form-container {
  display: flex;
  justify-content: space-between;
}
.form-container .info {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40%;
}
.form-container .info label {
  margin-top: 5rem;
}
.form-container .info input {
  width: 100%;
  padding: 0.5rem 0;
  background-color: transparent;
  border-radius: 6px;
  border: 1px solid black;
}

.message {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 2rem;
}
.message textarea {
  width: 100%;
  border-radius: 6px;
  border: 1px solid black;
  background-color: transparent;
}
.message ::placeholder {
  color: black;
}

.submit {
  align-self: center;
  width: 100%;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 2rem;
  margin-top: 2rem;
}
.submit input {
  padding: 0 2rem;
  background-color: transparent;
  border: black solid 1px;
  border-radius: 16px;
}

@media (min-width: 922px) and (max-width: 1200px) {
  .nav-top {
    width: 80vw !important;
    margin: 2rem 0;
  }

  .nav-bottom {
    width: 80%;
    margin: 2rem 10%;
  }

  main h1 {
    font-size: 60px;
  }
}
@media (min-width: 779px) and (max-width: 921px) {
  .nav-top {
    width: 90vw !important;
    margin: 2rem 0;
  }
  .nav-top .icon img {
    width: 10%;
  }
  .nav-top .icon h6 {
    display: none;
  }

  .nav-bottom {
    width: 90vw;
    margin: 2rem 5%;
  }

  main h1 {
    font-size: 50px;
  }
}
@media (min-width: 600px) and (max-width: 778px) {
  header .nav-top {
    width: 100vw;
    margin: 2rem 0;
  }
  header .nav-top ul {
    display: none;
  }
  header .nav-top .icon img {
    width: 10%;
  }
  header .burger-menu {
    margin-left: auto;
    width: 4rem;
    display: flex;
    align-items: center;
  }
  header .burger-menu .fas {
    font-size: 2.5rem;
    color: white;
    cursor: pointer;
    position: absolute;
    top: 2rem;
  }
  header .burger-menu input[type=checkbox] {
    display: none;
  }
  header .burger-menu input[type=checkbox]:checked ~ .burger__list {
    right: 0;
    display: flex;
  }
  header .burger-menu .burger__list {
    position: absolute;
    list-style: none;
    top: 4.5rem;
    width: 20%;
    display: flex;
    flex-direction: column;
    align-items: center;
    display: none;
    background-color: #89181e;
    border-radius: 0rem 0rem 0.5rem 0.5rem;
  }
  header .burger-menu .burger__list .burger__item {
    padding: 2rem 0rem;
  }
  header .burger-menu .burger__list .burger__item:hover,
header .burger-menu .burger__list .burger__item :visited,
header .burger-menu .burger__list .burger__item :link,
header .burger-menu .burger__list .burger__item :active {
    text-decoration: none;
    color: white;
  }

  .nav-bottom {
    width: 100%;
    margin: 0;
  }

  .container-projects .sub-container-projects {
    display: flex;
    flex-direction: column;
    align-items: center;
    align-items: flex-end;
  }
  .container-projects .sub-container-projects .pic {
    display: flex;
    justify-content: center;
  }
  .container-projects .sub-container-projects a {
    align-self: center;
    width: 80%;
  }
}
@media (max-width: 599px) {
  header .nav-top {
    width: 100vw !important;
    margin: 0 !important;
  }
  header .nav-top ul {
    display: none !important;
  }
  header .nav-top .icon img {
    width: 10%;
  }
  header .burger-menu {
    margin-left: auto;
    width: 4rem;
    display: flex;
    align-items: center;
  }
  header .burger-menu .fas {
    font-size: 2.5rem;
    color: white;
    cursor: pointer;
    position: absolute;
    top: 0.2rem;
  }
  header .burger-menu input[type=checkbox] {
    display: none;
  }
  header .burger-menu input[type=checkbox]:checked ~ .burger__list {
    right: 0;
    display: flex;
  }
  header .burger-menu .burger__list {
    position: absolute;
    list-style: none;
    top: 3rem;
    width: 40%;
    display: flex;
    flex-direction: column;
    align-items: center;
    display: none;
    background-color: #89181e;
    border-radius: 0rem 0rem 0.5rem 0.5rem;
    transition: all 0.4s ease-in;
  }
  header .burger-menu .burger__list .burger__item {
    padding: 2rem 0rem;
  }
  header .burger-menu .burger__list .burger__item:hover,
header .burger-menu .burger__list .burger__item :visited,
header .burger-menu .burger__list .burger__item :link,
header .burger-menu .burger__list .burger__item :active {
    text-decoration: none;
    color: white;
  }

  .nav-bottom {
    width: 100%;
    margin: 0;
  }

  main {
    width: 100vw;
    left: 0;
    text-align: center;
  }
  main h1 {
    font-size: 30px;
  }
  main p {
    width: 80%;
    margin: 0 auto;
  }

  .container-about .about {
    width: 80%;
  }

  .container-projects .sub-container-projects {
    display: flex;
    flex-direction: column;
    align-items: center;
    align-items: flex-end;
  }
  .container-projects .sub-container-projects .pic {
    display: flex;
    justify-content: center;
  }
  .container-projects .sub-container-projects a {
    align-self: center;
    width: 80%;
  }

  .form-container {
    flex-direction: column;
    align-items: center;
  }
}

